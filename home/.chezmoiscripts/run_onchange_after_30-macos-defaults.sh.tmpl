#!/bin/bash

set -eufo pipefail

{{ template "scripts/script_helper" . }}

# macOS defaults — runs whenever this script's content changes (chezmoi
# content-hashes it). `defaults write` is idempotent, so re-runs are safe.
#
# Discovery workflow for new prefs:
#   defaults read > /tmp/before.txt
#   <toggle the setting in System Settings>
#   defaults read > /tmp/after.txt
#   diff /tmp/before.txt /tmp/after.txt
#
# Apple removes/renames `defaults` keys between major macOS releases —
# verify each command on your target macOS version. References:
#   - https://github.com/mathiasbynens/dotfiles/blob/main/.macos
#     (older but still mostly valid)
#   - https://github.com/kevinSuttle/macOS-Defaults

log_info "Applying macOS defaults..."

# -----------------------------------------------------------------------------
# Trackpad / Mouse — secondary click = right click
# -----------------------------------------------------------------------------
defaults write com.apple.AppleMultitouchTrackpad TrackpadRightClick -bool true
defaults write com.apple.driver.AppleBluetoothMultitouch.trackpad TrackpadRightClick -bool true
defaults write com.apple.AppleMultitouchMouse MouseButtonMode -string TwoButton
defaults write com.apple.driver.AppleBluetoothMultitouch.mouse MouseButtonMode -string TwoButton

# -----------------------------------------------------------------------------
# Dock — minimalist (autohide, no recents, no magnification, small tiles)
# -----------------------------------------------------------------------------
defaults write com.apple.dock autohide -bool true
defaults write com.apple.dock autohide-delay -float 0
defaults write com.apple.dock autohide-time-modifier -float 0.4
defaults write com.apple.dock show-recents -bool false
defaults write com.apple.dock minimize-to-application -bool true
defaults write com.apple.dock magnification -bool false
defaults write com.apple.dock tilesize -int 36

# -----------------------------------------------------------------------------
# Menu bar — auto-hide (Sketchybar provides the visual replacement)
# -----------------------------------------------------------------------------
# Note: this only auto-hides the system menu bar; it still appears on
# hover at the top edge. Sketchybar runs as its own statusbar app.
defaults write NSGlobalDomain _HIHideMenuBar -bool true

# -----------------------------------------------------------------------------
# Window manager / Desktop (Sonoma+)
# -----------------------------------------------------------------------------
# Disable "Click wallpaper to reveal desktop" — stops clicks on any
# exposed desktop edge from hiding all your windows. Aerospace + tiling
# workflows rely on click-through behavior; this gets in the way.
defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -bool false

# Hide desktop icons (Files, Folders pinned to the desktop) — keeps the
# wallpaper clean. Pairs naturally with Aerospace's tiled workspace.
defaults write com.apple.WindowManager HideDesktop -bool true

# -----------------------------------------------------------------------------
# Disable Spotlight hotkeys (free Cmd+Space and Cmd+Opt+Space for Raycast)
# -----------------------------------------------------------------------------
# Symbolic hotkey 64 = "Show Spotlight search" (Cmd+Space)
# Symbolic hotkey 65 = "Show Finder search window" (Cmd+Opt+Space)
# Setting `enabled = false` releases the binding so Raycast can claim it.
# `value` is preserved so the original combo is restored if re-enabled.
# NOTE: needs a log-out / log-in (or reboot) to fully take effect — macOS
# caches symbolic hotkey state in the WindowServer process.
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 64 \
  "<dict><key>enabled</key><false/><key>value</key><dict><key>type</key><string>standard</string><key>parameters</key><array><integer>32</integer><integer>49</integer><integer>1048576</integer></array></dict></dict>"
defaults write com.apple.symbolichotkeys AppleSymbolicHotKeys -dict-add 65 \
  "<dict><key>enabled</key><false/><key>value</key><dict><key>type</key><string>standard</string><key>parameters</key><array><integer>32</integer><integer>49</integer><integer>1572864</integer></array></dict></dict>"

# -----------------------------------------------------------------------------
# Reload affected services
# -----------------------------------------------------------------------------
# `killall` is non-fatal so the script doesn't die in a VM where some
# of these UI services aren't running anyway.
killall cfprefsd 2>/dev/null || true   # flush prefs cache for symbolichotkeys
killall Dock 2>/dev/null || true
killall Finder 2>/dev/null || true
killall SystemUIServer 2>/dev/null || true

log_info "macOS defaults applied."
log_info "  • Caps Lock → Control: handled by Karabiner config (~/.config/karabiner/karabiner.json)"
log_info "  • Home folder in Finder sidebar: drag \$HOME into Finder → Settings → Sidebar (no clean defaults key)"
log_info "  • Some changes may require a log out / log in to fully apply."

