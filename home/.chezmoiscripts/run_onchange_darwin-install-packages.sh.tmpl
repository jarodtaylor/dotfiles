{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash

set -euo pipefail

echo "🍺 Installing Homebrew packages..."

brew bundle --no-lock --file=/dev/stdin <<EOF
{{ range .packages.darwin.brews -}}
brew {{ . | quote }}
{{ end -}}
{{ range .packages.darwin.casks -}}
cask {{ . | quote }}
{{ end -}}
EOF

echo "✅ Homebrew packages installed"
{{ end -}} 