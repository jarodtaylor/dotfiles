#!/bin/bash

set -eufo pipefail

{{ template "scripts/script_eval_brew" . }}
{{ template "scripts/script_sudo" . }}
{{ template "scripts/script_helper" . }}

# Hashes so chezmoi re-runs this script when its inputs change.
# Brewfile hash: {{ include "Brewfile" | sha256sum }}
# Mise config hash: {{ includeTemplate "dot_config/mise/config.toml.tmpl" | sha256sum }}
# Default npm packages hash: {{ includeTemplate "dot_config/mise/dot_default-npm-packages.tmpl" | sha256sum }}
# Default gems hash: {{ includeTemplate "dot_config/mise/dot_default-gems.tmpl" | sha256sum }}

BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"

# Install Homebrew if not present
if ! command -v brew &>/dev/null; then
  log_info "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$({{ .brew_prefix }}/bin/brew shellenv)"
fi

# Defensive: migrate any unversioned zsh-abbr to the pinned @6 variant.
# zsh-abbr@6 is declared in the Brewfile; this only cleans up legacy state.
if brew list zsh-abbr &>/dev/null; then
  log_info "Migrating unversioned zsh-abbr to @6..."
  brew unlink zsh-abbr
  brew uninstall --force zsh-abbr
fi

# Apply the declarative Brewfile. Individual casks sometimes fail (kext
# approval, LaunchDaemon registration quirks, one-off network issues);
# we don't want those to abort the whole bootstrap. Install best-effort,
# then report what didn't land so the user can install manually.
log_info "Applying Brewfile (install — best-effort, non-fatal on cask failures)..."
if ! brew bundle install --file="$BREWFILE" --verbose; then
  log_warning "Some Brewfile dependencies failed to install. Listing what's missing:"
  brew bundle check --file="$BREWFILE" --verbose || true
  log_warning "Install the missing items manually (e.g., 'brew install --cask NAME') after bootstrap."
fi

log_info "Pruning packages not in Brewfile..."
if ! brew bundle cleanup --file="$BREWFILE" --force; then
  log_warning "Brew cleanup encountered issues; non-fatal, bootstrap continues."
fi

# Configure mise (development tool version manager)
if command -v mise &>/dev/null; then
    log_info "Upgrading mise and managing development tools..."
    mise upgrade

    prunable_output=$(mise ls --prunable 2>/dev/null || true)
    if [ -n "$prunable_output" ]; then
        echo "$prunable_output" | while IFS= read -r item; do
            if [ -n "$item" ]; then
                log_debug "Pruning removed tool: $item"
                mise prune "$item"
            fi
        done
    fi
else
    log_warning "Warning: mise not found. Package installation may have failed."
fi
