[tools]
{{- range $lang, $content := .mise }}
  {{- if $content.enabled }}
    {{- range $ver := $content.versions }}
      {{ $lang }} = { version = {{ $ver | quote }}
      {{- if and $content.options (ne $content.options nil) }}
        {{- range $key, $value := $content.options }}, {{ $key }} = {{ $value | quote }}{{- end }}
      {{- end }}
      }
    {{- end }}
  {{- end }}
{{- end }}

# supports everything you can do with .tool-versions currently
# nodejs = ['16', 'prefix:20', 'ref:master', 'path:~/.nodes/14']

# send arbitrary options to the plugin, passed as:
# MISE_TOOL_OPTS__VENV=.venv
# python = {version='3.10', virtualenv='.venv'}

[plugins]
# specify a custom repo url
# note this will only be used if the plugin does not already exist
# python = 'https://github.com/asdf-community/asdf-python'

# {{ template "settings.toml.tmpl" . }}
