
# +-----------------+
# | ZIM FRAMEWORK |
# +----------------+
# The prefix for the alias from zim builtin git module
# zstyle ':zim:zmodule' use 'degit'
zstyle ':zim:input' double-dot-expand yes

export ZIM_CONFIG_FILE="${XDG_CONFIG_HOME}/zsh/.zimrc"
export ZIM_HOME="${XDG_CACHE_HOME}/zim"

# Download zimfw plugin manager if missing.
if [[ ! -e ${ZIM_HOME}/zimfw.zsh ]]; then
  echo "Downloading zimfw plugin manager..."
  if ! curl -fsSL --create-dirs -o ${ZIM_HOME}/zimfw.zsh \
    https://github.com/zimfw/zimfw/releases/latest/download/zimfw.zsh; then
    echo "Failed to download zimfw. Check your internet connection or the URL."
    return 1
  fi
fi

# Install missing modules and update ${ZIM_HOME}/init.zsh if missing or outdated.
if [[ ! ${ZIM_HOME}/init.zsh -nt ${ZIM_CONFIG_FILE:-${ZDOTDIR:-${HOME}}/.zimrc} ]]; then
  source ${ZIM_HOME}/zimfw.zsh init -q
fi

# Initialize modules.
source ${ZIM_HOME}/init.zsh

## init zsh-abbr
source ${ZIM_HOME}/modules/zsh-abbr/zsh-abbr.zsh

# +-----------------+
# | INPUT CONFIG   |
# +-----------------+
# Set editor default keymap to emacs (`-e`) or vi (`-v`)
# bindkey -v

# +-----------------+
# | INITIALIZATION |
# +----------------+

# Initialize fzf key bindings and fuzzy completion
source <(fzf --zsh)

for file in "$ZDOTDIR"/functions/*.zsh; do
  source "$file"
done

# Track if the shell has just started
ZSH_FIRST_PROMPT=true

add_newline_after_command() {
    # Skip adding a newline on the first prompt
    if [[ "$ZSH_FIRST_PROMPT" = true ]]; then
        ZSH_FIRST_PROMPT=false
        return
    fi

    # Add a newline only after a command with output
    if [[ -n "$(fc -ln -1)" ]]; then
        print -n "\n"
    fi
}

# Hook the newline function to the precmd hook
precmd_functions+=(add_newline_after_command)



