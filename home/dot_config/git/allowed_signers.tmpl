{{- if ne .ssh_key "" -}}
# Maps signing identities to their public keys so `git log --show-signature` can
# verify SSH-signed commits locally. Public keys only -- safe to commit.
# Managed by chezmoi; keys and the work principal come from the 1Password-backed chezmoi data.
# namespaces="git" restricts each key to Git's signing namespace (not other SSH uses).
jarodrtaylor@gmail.com namespaces="git" {{ .ssh_key }}
{{- if and (ne .work_ssh_key "") (ne .work_email "") }}
{{ .work_email }} namespaces="git" {{ .work_ssh_key }}
{{- end }}
{{ end -}}
