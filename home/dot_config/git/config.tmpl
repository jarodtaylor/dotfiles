[user]
  name  = "Jarod Taylor"
  email = "jarodrtaylor@gmail.com"
  # Sign with the on-disk key file (chezmoi writes it from 1Password), not the
  # 1Password SSH agent, so unattended commits work when the vault is locked.
  # See docs/1password-ssh-signing-rca.md.
  signingkey = ~/.ssh/id

{{- if stat (joinPath .chezmoi.homeDir ".config/git/config-work") }}
[includeIf "gitdir:{{ .work_dir }}/"]
  path = config-work
{{- end }}

[include]
  path = conf.d/delta.conf

[color]
  ui = auto
  diff = auto
  status = auto
  branch = auto

[color "status"]
  added = blue
  updated = green
  changed = yellow
  untracked = cyan
  branch = magenta
  nobranch = normal
  unmerged = red

[init]
	defaultBranch = main

[branch]
  autosetuprebase = always

[core]
  editor = vim

[remote]
  pushDefault = origin

[fetch]
  prune = true

[merge]
  conflictStyle = zdiff3
  branchdesc = true
  log = true

[push]
  default = current

[pull]
  ff = only

[commit]
  gpgsign = true

[gpg]
  format = ssh
{{- if lookPath "ssh-keygen" }}
  program = {{ lookPath "ssh-keygen" }}
{{- end }}

[gpg "ssh"]
  # Verify SSH commit signatures locally against an allow-list of pubkeys.
  allowedSignersFile = ~/.config/git/allowed_signers

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
