[user]
  name  = "Jarod Taylor"
  email = "jarodrtaylor@gmail.com"
  signingkey = {{ .ssh_key }}

[includeIf "gitdir:{{ .work_dir }}/"]
  path = config-work.tmpl

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[commit]
  gpgsign = true

[include]
  path = conf.d/delta.conf

[color]
  ui = true
  diff = auto
  status = auto
  branch = auto

[init]
	defaultBranch = main

[branch]
  autosetuprebase = always

[core]
  editor = vim

[remote]
  pushDefault = origin

[fetch]
  prune = true

[merge]
  conflictStyle = zdiff3
  branchdesc = true
  log = true

[push]
  default = current

[pull]
  ff = only
