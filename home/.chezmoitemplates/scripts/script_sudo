#!/bin/bash

# Prime the sudo timestamp with one interactive prompt, then start a
# background keep-alive loop that refreshes it every 60s for the life of
# this script. Without the priming prompt, `sudo -n true` below would fail
# silently on a fresh shell (no existing timestamp) and each subsequent
# brew cask install would prompt again.
#
# `sudo -v` can fail if sudo_local references a PAM module that's missing
# (e.g. pam_watchid.so.2 on Macs / VMs without Apple Watch support). Don't
# abort the whole apply on a PAM glitch — fall back to per-command prompts.
sudo -v || echo "(sudo priming failed — individual commands may prompt)" >&2
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &
