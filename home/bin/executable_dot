#!/usr/bin/env bash
# dot — personal dotfiles management CLI
#
# Commands:
#   sync         Capture drift into repo, optionally commit/push
#   apply        chezmoi apply + brew bundle --cleanup
#   doctor       Multi-layer health check
#   status       One-line drift summary (exit 1 if drift)
#   new-machine  Interactive bootstrap helper for first-time setup
#   edit         Open the repo in $EDITOR
#   help         Show this help
#
# See README.md and docs/TESTING.md in the dotfiles repo for context.

set -euo pipefail

DOTS_SOURCE_DIR="$(chezmoi source-path 2>/dev/null || echo "$HOME/.local/share/chezmoi/home")"
# chezmoi source-path already resolves .chezmoiroot, so $DOTS_SOURCE_DIR is e.g. ~/.local/share/chezmoi/home
DOTS_REPO_DIR="$(dirname "$DOTS_SOURCE_DIR")"
DOTS_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/dots-sync"
mkdir -p "$DOTS_STATE_DIR"

# --- Logging ---
if [ -t 1 ]; then
  C_RESET=$'\033[0m'; C_BLUE=$'\033[34m'; C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'; C_DIM=$'\033[2m'
else
  C_RESET=''; C_BLUE=''; C_GREEN=''; C_YELLOW=''; C_RED=''; C_DIM=''
fi

log_info()  { printf "%s➜%s %s\n" "$C_BLUE"   "$C_RESET" "$*"; }
log_ok()    { printf "%s✓%s %s\n" "$C_GREEN"  "$C_RESET" "$*"; }
log_warn()  { printf "%s⚠%s %s\n" "$C_YELLOW" "$C_RESET" "$*"; }
log_err()   { printf "%s✗%s %s\n" "$C_RED"    "$C_RESET" "$*" >&2; }
log_debug() { [ "${DOTS_VERBOSE:-0}" = "1" ] && printf "%s  %s%s\n" "$C_DIM" "$*" "$C_RESET" || true; }

# --- Usage ---
usage() {
  cat <<'USAGE'
dot — personal dotfiles management CLI

Usage:
  dot <command> [flags]

Commands:
  sync          Capture drift into repo, optionally commit/push
  apply         chezmoi apply + brew bundle --cleanup
  doctor        Multi-layer health check
  status        One-line drift summary (exit 1 if drift)
  new-machine   Interactive bootstrap helper
  edit          Open the repo in $EDITOR
  help          Show this help

Common flags:
  --dry-run     Preview without writing
  --no-commit   sync: capture but don't auto-commit
  --push        sync: push to origin after commit
  -v,--verbose  Show underlying commands

Examples:
  dot sync --dry-run       # Preview what would be captured
  dot sync --push          # Capture + commit + push
  dot doctor               # Show system health
  dot apply                # Reconcile machine with repo
USAGE
}

cmd_help() { usage; }

# --- sync ---
cmd_sync() {
  local dry_run=0 no_commit=0 do_push=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run)    dry_run=1 ;;
      --no-commit)  no_commit=1 ;;
      --push)       do_push=1 ;;
      -v|--verbose) export DOTS_VERBOSE=1 ;;
      *) log_warn "unknown flag: $1" ;;
    esac
    shift
  done

  local brewfile="$DOTS_SOURCE_DIR/Brewfile"

  # 1. Dump Homebrew state
  log_info "capturing Homebrew state..."
  if [ "$dry_run" = "1" ]; then
    local tmpdump
    tmpdump="$(mktemp)"
    brew bundle dump --force --describe --file="$tmpdump" >/dev/null
    if ! diff -u "$brewfile" "$tmpdump" >/dev/null 2>&1; then
      log_warn "Brewfile would change. Preview diff:"
      diff -u "$brewfile" "$tmpdump" | head -40
    else
      log_ok "Brewfile is in sync"
    fi
    rm -f "$tmpdump"
  else
    brew bundle dump --force --describe --file="$brewfile"
  fi

  # 2. Update already-tracked AI tool files from live state.
  # Using `re-add` (not `add`) so template files stay templates and we
  # don't get prompted every sync about "downgrading" .tmpl to plain.
  # Trade-off: brand-new files (e.g. a new skill) are NOT auto-captured.
  # To start tracking new paths, run `chezmoi add <path>` explicitly once,
  # then subsequent `dot sync` runs will keep them updated.
  log_info "updating tracked AI tool files..."
  if [ "$dry_run" = "1" ]; then
    log_debug "(dry-run) would: chezmoi re-add"
  else
    chezmoi re-add 2>&1 | grep -vE '^$' || true
  fi

  # 3. Show diff
  cd "$DOTS_REPO_DIR" || exit 1
  if git diff --quiet && git diff --cached --quiet; then
    log_ok "no drift — repo is in sync"
    return 0
  fi

  log_info "drift detected:"
  git --no-pager diff --stat HEAD | sed 's/^/  /'

  if [ "$dry_run" = "1" ]; then
    log_info "dry-run: stopping here"
    return 0
  fi

  if [ "$no_commit" = "1" ]; then
    log_info "--no-commit: leaving changes unstaged"
    return 0
  fi

  # 4. Commit
  local summary
  summary="$(git diff --stat HEAD | tail -1)"
  git add -A
  git commit -m "state sync $(date +%Y-%m-%d): $summary"

  # 5. Optional push
  if [ "$do_push" = "1" ]; then
    log_info "pushing to origin..."
    git push
    log_ok "pushed"
  fi

  log_ok "sync complete"
}

# --- apply ---
cmd_apply() {
  local dry_run=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run)    dry_run=1 ;;
      -v|--verbose) export DOTS_VERBOSE=1 ;;
      *) log_warn "unknown flag: $1" ;;
    esac
    shift
  done

  local chezmoi_flags=(-v)
  if [ "$dry_run" = "1" ]; then
    chezmoi_flags+=(--dry-run)
  fi

  log_info "chezmoi apply..."
  chezmoi apply "${chezmoi_flags[@]}"

  if [ "$dry_run" = "0" ]; then
    log_info "brew bundle install + cleanup..."
    brew bundle install --file="$DOTS_SOURCE_DIR/Brewfile" || \
      log_warn "brew bundle install reported issues; non-fatal"
    brew bundle cleanup --file="$DOTS_SOURCE_DIR/Brewfile" --force || \
      log_warn "brew bundle cleanup reported issues; non-fatal"
  else
    log_info "(dry-run) would run: brew bundle install + cleanup"
  fi

  log_ok "apply complete"
}

# --- doctor ---
cmd_doctor() {
  local fail=0

  echo
  log_info "== chezmoi =="
  if chezmoi doctor 2>&1 | tail -20; then
    log_ok "chezmoi doctor ran"
  else
    log_err "chezmoi doctor reported issues"
    fail=1
  fi

  echo
  log_info "== Homebrew =="
  if brew bundle check --file="$DOTS_SOURCE_DIR/Brewfile" --verbose; then
    log_ok "Brewfile in sync with installed state"
  else
    log_warn "Brewfile drift (run 'dot sync' to capture or 'dot apply' to reconcile)"
    fail=1
  fi

  echo
  log_info "== Source repo =="
  local repo_status
  repo_status="$(git -C "$DOTS_REPO_DIR" status --porcelain)"
  if [ -z "$repo_status" ]; then
    log_ok "repo clean, nothing uncommitted"
  else
    log_warn "uncommitted changes in repo:"
    echo "$repo_status"
    fail=1
  fi

  echo
  log_info "== 1Password =="
  if command -v op >/dev/null 2>&1; then
    if op whoami >/dev/null 2>&1; then
      log_ok "1Password CLI signed in ($(op whoami 2>/dev/null | awk '/^Email:/ {print $2}'))"
    else
      log_warn "1Password CLI installed but not signed in (run 'op signin')"
      fail=1
    fi
  else
    log_warn "1Password CLI not installed"
    fail=1
  fi

  echo
  log_info "== dots-sync launchd agent =="
  if launchctl print "gui/$(id -u)/com.jarodtaylor.dots-sync" >/dev/null 2>&1; then
    local last_run
    last_run="$(stat -f '%Sm' "$DOTS_STATE_DIR/stdout.log" 2>/dev/null || echo 'never')"
    log_ok "launchd agent loaded (last log write: $last_run)"
  else
    log_warn "launchd agent not loaded — set up in Phase 3 (ok for now)"
  fi

  echo
  log_info "== AI tool directories =="
  local tool_dir
  for tool_dir in "$HOME/.claude" "$HOME/.codex" "$HOME/.cursor"; do
    if [ -d "$tool_dir" ]; then
      log_ok "$(basename "$tool_dir") exists"
    else
      log_warn "$(basename "$tool_dir") missing"
    fi
  done

  echo
  if [ "$fail" = "0" ]; then
    log_ok "All checks passed."
  else
    log_warn "Some checks flagged attention (see above)."
  fi
  return "$fail"
}

# --- status (one-line, shell-friendly) ---
cmd_status() {
  local dirty=0 brew_drift=0

  if ! git -C "$DOTS_REPO_DIR" diff-index --quiet HEAD -- 2>/dev/null; then
    dirty=1
  fi
  if ! brew bundle check --file="$DOTS_SOURCE_DIR/Brewfile" >/dev/null 2>&1; then
    brew_drift=1
  fi

  if [ "$dirty" = "0" ] && [ "$brew_drift" = "0" ]; then
    echo "clean"
    return 0
  fi

  local parts=()
  [ "$dirty" = "1" ]      && parts+=("repo-dirty")
  [ "$brew_drift" = "1" ] && parts+=("brew-drift")

  ( IFS=,; echo "${parts[*]}" )
  return 1
}

# --- new-machine (walkthrough + doctor) ---
cmd_new_machine() {
  cat <<'EOM'
New-machine setup helper.

Expected state: you've already run bootstrap.sh or the chezmoi one-liner.
This command checks prereqs and runs 'dot doctor'.

Typical post-bootstrap steps (do manually if needed):
  1) Open a fresh shell so PATH is updated.
  2) Verify 1Password CLI session: op whoami
  3) Run 'dot doctor' and fix any warnings.
  4) Restart macOS once to let launchd agents pick up cleanly.
  5) Manual installs (see docs/KNOWN_ISSUES.md):
       brew tap elc-online/tap git@github.com:elc-online/homebrew-tap.git
       brew install elc-online/tap/elco
       brew install --cask expressvpn  # or from expressvpn.com

EOM

  log_info "verifying prereqs..."
  local ok=1

  if command -v op >/dev/null 2>&1 && op whoami >/dev/null 2>&1; then
    log_ok "1Password signed in"
  else
    log_warn "1Password not signed in — run 'op signin'"
    ok=0
  fi

  if command -v chezmoi >/dev/null 2>&1; then
    log_ok "chezmoi installed"
  else
    log_err "chezmoi not installed — did bootstrap.sh complete?"
    ok=0
  fi

  if command -v brew >/dev/null 2>&1; then
    log_ok "brew installed"
  else
    log_err "brew not installed — did bootstrap.sh complete?"
    ok=0
  fi

  if [ "$ok" = "1" ]; then
    log_info "prereqs ok. Running 'dot doctor':"
    echo
    cmd_doctor
  else
    log_err "fix the above before continuing"
    return 1
  fi
}

# --- edit ---
cmd_edit() { "${EDITOR:-vi}" "$DOTS_REPO_DIR"; }

# --- dispatch ---
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    sync)        cmd_sync "$@" ;;
    apply)       cmd_apply "$@" ;;
    doctor)      cmd_doctor "$@" ;;
    status)      cmd_status "$@" ;;
    new-machine) cmd_new_machine "$@" ;;
    edit)        cmd_edit "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      log_err "Unknown command: $cmd"
      echo
      usage
      exit 64
      ;;
  esac
}

main "$@"
