{{- $brew_prefix := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   if eq .chezmoi.arch "arm64" -}}
{{-     $brew_prefix = "/opt/homebrew" -}}
{{-   else if eq .chezmoi.arch "amd64" -}}
{{-     $brew_prefix = "/usr/local" -}}
{{-   end -}}
{{- end -}}

[data]
brew_prefix = {{ $brew_prefix | quote }}
code_dir = "~/Code"
work_dir = "~/Code/work"

[diff]
command = "delta"
pager = "delta"
