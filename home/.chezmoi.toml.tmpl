{{- $brew_prefix := "" -}}
{{- if eq .chezmoi.os "darwin" -}}
{{-   if eq .chezmoi.arch "arm64" -}}
{{-     $brew_prefix = "/opt/homebrew" -}}
{{-   else if eq .chezmoi.arch "amd64" -}}
{{-     $brew_prefix = "/usr/local" -}}
{{-   end -}}
{{- end -}}

{{/* 1Password + age availability: derive the age recipient with a SINGLE real
     `op read`, NOT `op whoami`. Under the 1Password app's CLI integration
     `op whoami` reports "not signed in" with no cached session even though
     `op read` works via a biometric prompt, so the old whoami gate disabled
     1Password (encryption + all data) until you ran `op signin`. The read is
     piped straight through `age-keygen -y`, so only the PUBLIC recipient is ever
     captured -- never the raw secret. A non-empty recipient means op is
     reachable: enable encryption + 1P data. Empty is the graceful fallback
     (fresh machine, op missing, age-keygen missing, or "Personal/Dotfiles Age
     Key" renamed) -- note this couples ALL 1P data to that one entry + age-keygen,
     which are required infra here anyway. Caveat: like every `onepasswordRead`
     here, an interactive run may prompt for biometric; a headless run with no
     cached session blocks on that prompt. */}}
{{- $ageRecipient := "" -}}
{{- if lookPath "op" -}}
{{-   $ageRecipient = output "sh" "-c" "op read 'op://Dotfiles/Dotfiles Age Key/notesPlain' 2>/dev/null | age-keygen -y 2>/dev/null || true" | trim -}}
{{- end -}}
{{- $opAvailable := ne $ageRecipient "" -}}
{{- $ageAvailable := $opAvailable -}}

{{- if $ageAvailable }}
encryption = "age"

{{/* Identity file is a derived cache written by bootstrap.sh from the
     authoritative 1Password entry. chezmoi has no native way to source an
     age identity from a command at apply time (only identity file,
     identities, or identityFile+passphrase). On-disk key is 0600 and
     lives alongside chezmoi's own state. See docs/KNOWN_ISSUES.md. */}}
[age]
identity = "{{ joinPath .chezmoi.homeDir ".config/chezmoi/key.txt" }}"
recipient = {{ $ageRecipient | quote }}
{{- end }}

[data]
brew_prefix = {{ $brew_prefix | quote }}
ageAvailable = {{ $ageAvailable }}
{{- if $opAvailable }}
ssh_key = "{{- onepasswordRead "op://Dotfiles/4ytcjbe2ui6iz5sjfe7fn54jea/public_key" -}}"
work_ssh_key = "{{- onepasswordRead "op://Dotfiles/orsplwhcmkbfmxdwbf6udvpjvu/public_key" -}}"
work_email = "{{- onepasswordRead "op://Dotfiles/orsplwhcmkbfmxdwbf6udvpjvu/email" -}}"
onepassword_available = true
{{- else }}
ssh_key = ""
work_ssh_key = ""
work_email = ""
onepassword_available = false
{{- end }}
code_dir = "~/Code"
work_dir = "~/Code/work"

[[data.profiles]]
id = "personal"
code_dir = "~/Code/personal"
email = "jarodrtaylor@gmail.com"
name = "Jarod Taylor"
create_directory = true

[[data.profiles]]
id = "work"
code_dir = "~/Code/work"
create_directory = true

{{- if lookPath "delta" }}

[diff]
command = "delta"
pager = "delta"
{{- end }}
