# -----------------------------------------------------------------------------
# Casks — interactive installers (expect password prompts in this section)
# -----------------------------------------------------------------------------
# These casks use pkg installers with LaunchDaemons, kernel extensions, or
# privileged helpers. They trigger macOS Authorization Services prompts (GUI
# password dialogs) that CANNOT be suppressed by sudo timestamp caching —
# Auth Services has no timestamp concept. Grouped here so the prompts come
# in one back-to-back burst at the very end of bootstrap instead of
# scattering across the 30-min install.
#
# Stand by for ~6 password prompts when this section runs.
cask "adobe-creative-cloud"
cask "blackhole-2ch"                # virtual audio device (driver install)
cask "docker-desktop"               # privileged helper + docker socket
cask "karabiner-elements"           # Karabiner VirtualHID driver
cask "microsoft-outlook"            # MS AutoUpdate daemon
cask "microsoft-teams"              # MS AutoUpdate daemon
cask "zoom"                         # historically uses privileged helper
