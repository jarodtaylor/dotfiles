# =============================================================================
# Brewfile — Jarod Taylor's macOS dotfiles
# =============================================================================
# Managed by chezmoi + `dot sync`.
#
# Apply:   brew bundle --file="$(chezmoi source-path)/Brewfile" --cleanup
# Capture: dot sync    (runs `brew bundle dump --force --describe` + commits)
#
# Note: `dot sync` rewrites this file flat-alphabetized via `brew bundle dump`,
# which strips section comments and manual grouping. This hand-curated layout
# is primarily useful on first-machine bootstrap (see "interactive installers"
# section at the bottom — grouping prompt-heavy casks bunches macOS GUI
# password prompts into one attention burst instead of scattering them
# across a 30-min install). Subsequent `dot sync` runs will flatten it.
#
# Keep this file alphabetized within each group for diff-friendliness.

# -----------------------------------------------------------------------------
# Taps
# -----------------------------------------------------------------------------
tap "alltuner/tap"                  # factoryfloor
tap "felixkratz/formulae"           # sketchybar, borders
# NOTE: elco is tapped from a private repo (elc-online/homebrew-tap) which
# needs SSH auth. Not in the bootstrap Brewfile because the SSH env isn't
# fully wired during chezmoi apply. Install manually post-bootstrap:
#   brew tap elc-online/tap git@github.com:elc-online/homebrew-tap.git
#   brew install elc-online/tap/elco
tap "nikitabobko/tap"               # aerospace window manager
tap "olets/tap"                     # zsh-abbr, zsh-autosuggestions-abbreviations-strategy

