{
    // File associations for template files
    "files.associations": {
        "*.sh.tmpl": "shellscript",
        "*.toml.tmpl": "toml",
        "*.json.tmpl": "json",
        "*.yaml.tmpl": "yaml",
        "*.yml.tmpl": "yaml",
        "*.conf.tmpl": "ini",
        "nginx.conf.tmpl": "nginx",
        "apache.conf.tmpl": "apache",
        "ssh_config.tmpl": "ssh-config"
    },

    // Shell script specific settings (applies to .sh files)
    "[shellscript]": {
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.defaultFormatter": "foxundermoon.shell-format",
        "editor.formatOnSave": true
    },

    // Template files with shell content
    "[shellscript.tmpl]": {
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    },

    // TOML settings (for chezmoi config files)
    "[toml]": {
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,
        "editor.defaultFormatter": "tamasfe.even-better-toml"
    },

    // ShellCheck settings
    "shellcheck.enable": true,
    "shellcheck.useWorkspaceRootAsCwd": true,
    "shellcheck.run": "onSave",
    "shellcheck.ignorePatterns": {
        "**/*.tmpl": true  // Ignore template files as they might have template syntax
    },

    // Optional: Better template highlighting
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true
} 